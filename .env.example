# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your own values before running the project.
#
#   cp .env.example .env
#
# ──────────────────────────────────────────────────────────────────────────────

# Database (PostgreSQL)
DB_NAME=mosquiztodb
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Mail (Gmail SMTP)
# Use a Gmail App Password, not your normal Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
MAIL_ADDRESS=your_email@gmail.com
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# JWT Secret Keys
# Use any random base64 string (minimum 32 characters recommended).
# Generate with: openssl rand -base64 32
JWT_ACCESS_KEY=your_jwt_access_secret_key
JWT_REFRESH_KEY=your_jwt_refresh_secret_key
JWT_RESET_KEY=your_jwt_reset_secret_key

# Server URL (use "localhost" for local development, or your VPS IP for deployment)
VPS_IP=localhost
