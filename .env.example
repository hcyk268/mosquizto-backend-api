# Copy this file to .env before running docker compose.
# Linux/macOS/Git Bash: cp .env.example .env
# Windows PowerShell:  Copy-Item .env.example .env
#
# This file is consumed by docker-compose.yml.
# If you run the app directly via Maven or an IDE, see README.md for the
# Spring-specific environment variables you need to export manually.

# Database (PostgreSQL)
DB_NAME=mosquiztodb
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Redis
# Use redis with Docker Compose; use localhost when running the app directly.
REDIS_HOST=redis
REDIS_PORT=6379

# Mail provider
# Keep MAIL_* populated because docker-compose maps them to Spring mail props.
APP_MAIL_PROVIDER=smtp

# SMTP (Gmail)
# Use a Gmail App Password, not your normal Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
MAIL_ADDRESS=your_email@gmail.com
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# SendGrid
# Required when APP_MAIL_PROVIDER=sendgrid.
SEND_GRID=your_sendgrid_api_key

# JWT secret keys
# Generate each key separately with: openssl rand -base64 48
JWT_ACCESS_KEY=your_jwt_access_secret_key
JWT_REFRESH_KEY=your_jwt_refresh_secret_key
JWT_RESET_KEY=your_jwt_reset_secret_key

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Meilisearch
# Generate a strong key with: openssl rand -base64 48
MEILI_MASTER_KEY=your_meilisearch_master_key
# Docker Compose service address; use http://localhost:7700 outside Docker.
MEILI_SEARCH_HOST=http://meilisearch:7700

# Public host used to build SERVER_URL inside docker-compose.yml
VPS_IP=localhost

# WebSocket
WS_MESSAGE_TIME_OUT=500
WS_CONNECT_ENDPOINT=/ws-connection
